# fcmanager.app — FCManager(멀티테넌트 SaaS) nginx 예시.
# dolfinid 의 /etc/nginx/sites-available/fcmanager 로 복사 후 sites-enabled 에 심링크.
# 컨테이너는 127.0.0.1:8003 (compose). 정적은 컨테이너 내 WhiteNoise 가 /static/ 으로 서빙,
# 미디어는 호스트 /srv/fcmanager/media 를 nginx 가 직접 서빙.
#
# 적용:
#   sudo cp deploy/host/nginx-fcmanager.conf.example /etc/nginx/sites-available/fcmanager
#   sudo ln -s /etc/nginx/sites-available/fcmanager /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d fcmanager.app -d www.fcmanager.app   # HTTPS 자동 구성
#
# certbot --nginx 가 아래 80 포트 블록에 TLS(443) 설정을 자동 추가/리다이렉트한다.

server {
    listen 80;
    listen [::]:80;
    server_name fcmanager.app www.fcmanager.app;

    client_max_body_size 20m;   # 로고·사진 업로드 여유

    # 미디어: 호스트 디렉토리 직접 서빙 (컨테이너 볼륨과 동일 경로)
    location /media/ {
        alias /srv/fcmanager/media/;
        access_log off;
        expires 7d;
    }

    # 나머지(플랫폼 /, 클럽 /<slug>/, /static/(WhiteNoise), /admin/, /accounts/, /clubs/new/)
    location / {
        proxy_pass http://127.0.0.1:8003;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;   # HTTPS 인식(보안 쿠키·CSRF)
    }
}

# (참고) 기존 /FCManager/ 경로를 쓰던 북마크를 새 도메인으로 보내려면, FCManager 가 얹혀 있던
# 기존 사이트(예: 2026biennale) 의 server 블록에 아래를 추가:
#
#   location /FCManager/ {
#       return 301 https://fcmanager.app/fcsky/;
#   }
#   location = /FCManager  { return 301 https://fcmanager.app/fcsky/; }
